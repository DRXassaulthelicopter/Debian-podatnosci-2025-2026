# =============================================================================
# CVE Scan API — konfiguracja środowiskowa
# Skopiuj do /etc/cve-scan-api/scanner.env i ustaw chmod 600
# =============================================================================

# --- Serwer HTTP ---
CVE_LISTEN=127.0.0.1
CVE_PORT=8088
CVE_MAX_BODY=1048576          # 1 MiB — maksymalny rozmiar body żądania POST

# --- Autoryzacja HTTP (opcjonalna, ale zalecana w produkcji) ---
# Wygeneruj np.: python3 -c "import secrets; print(secrets.token_hex(32))"
CVE_API_TOKEN=ZMIEN_NA_LOSOWY_TOKEN

# --- NVD API ---
# Klucz API: https://nvd.nist.gov/developers/request-an-api-key
# Bez klucza limit żądań: ~5 req/30 s; z kluczem: ~50 req/30 s
NVD_API_KEY=ZMIEN_NA_KLUCZ_NVD
CVE_HTTP_TIMEOUT=20           # timeout żądań HTTP do NVD (sekundy)
# CVE_NVD_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# --- Cache NVD ---
CVE_CACHE_ENABLED=1
CVE_CACHE_PATH=/var/cache/cve-scan-api/nvd_cache.json
CVE_CACHE_TTL=86400           # 24 h — czas życia wpisu cache (sekundy)

# --- Logowanie ---
CVE_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
CVE_LOG_JSON=0                # 1 = JSON (dla Loki/ELK), 0 = tekst (dla journald)
CVE_LOG_REQUEST_ID=1          # 1 = dołącz request_id do każdego wpisu logu
